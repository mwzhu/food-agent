SHOPPER_APP_ENV=development
SHOPPER_DATABASE_URL=sqlite+aiosqlite:///./shopper.db
SHOPPER_LLM_PROVIDER=anthropic
SHOPPER_LLM_MODEL=claude-sonnet-4-6
SHOPPER_LLM_TEMPERATURE=0.2
SHOPPER_EMBEDDING_PROVIDER=openai
SHOPPER_EMBEDDING_MODEL=text-embedding-3-small
SHOPPER_QDRANT_URL=http://localhost:6333
SHOPPER_QDRANT_COLLECTION=recipes
SHOPPER_RERANKER_PROVIDER=cross_encoder
SHOPPER_RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
SHOPPER_CONTEXT_TOKENIZER=cl100k_base
LANGSMITH_TRACING=false
LANGSMITH_PROJECT=shopper
LANGSMITH_API_KEY=
BROWSER_USE_API_KEY=
SHOPPER_CHECKOUT_ARTIFACTS_DIR=data/checkout_artifacts
SHOPPER_CHECKOUT_MAX_ORDER_TOTAL_USD=200
SHOPPER_CHECKOUT_MAX_WEEKLY_TOTAL_USD=500
SHOPPER_BROWSER_CHECKOUT_HEADLESS=true
SHOPPER_BROWSER_CHECKOUT_MAX_STEPS=80
SHOPPER_BROWSER_CHECKOUT_USE_CLOUD=false
SHOPPER_BROWSER_CHECKOUT_CLOUD_PROFILE_ID=
SHOPPER_BROWSER_CHECKOUT_CLOUD_PROXY_COUNTRY_CODE=
SHOPPER_BROWSER_CHECKOUT_CLOUD_TIMEOUT_MINUTES=
SHOPPER_BROWSER_CHECKOUT_CAPTCHA_SOLVER=true
SHOPPER_BROWSER_CHECKOUT_USER_DATA_DIR=
SHOPPER_BROWSER_CHECKOUT_STORAGE_STATE_PATH=
SHOPPER_BROWSER_CHECKOUT_MODEL_PROVIDER=shopper_default
SHOPPER_BROWSER_CHECKOUT_MODEL=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
USDA_API_KEY=
