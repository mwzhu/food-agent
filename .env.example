SHOPPER_APP_ENV=development
SHOPPER_DATABASE_URL=sqlite+aiosqlite:///./shopper.db
SHOPPER_LLM_PROVIDER=anthropic
SHOPPER_LLM_MODEL=claude-3-5-sonnet-latest
SHOPPER_LLM_TEMPERATURE=0.2
SHOPPER_EMBEDDING_PROVIDER=openai
SHOPPER_EMBEDDING_MODEL=text-embedding-3-small
SHOPPER_QDRANT_URL=http://localhost:6333
SHOPPER_QDRANT_COLLECTION=recipes
SHOPPER_RERANKER_PROVIDER=cross_encoder
SHOPPER_RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
SHOPPER_CONTEXT_TOKENIZER=cl100k_base
LANGSMITH_TRACING=false
LANGSMITH_PROJECT=shopper
LANGSMITH_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
USDA_API_KEY=
